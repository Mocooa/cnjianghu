# Optional Plausible analytics
# Create a site in Plausible for your current domain, then set:
PUBLIC_PLAUSIBLE_DOMAIN=cnjianghu.vercel.app

# Optional override if you self-host Plausible.
PUBLIC_PLAUSIBLE_API_HOST=https://plausible.io

# Optional Google Search Console HTML tag verification token.
# Example: if Search Console gives
# <meta name="google-site-verification" content="abc123" />
# then set:
PUBLIC_GOOGLE_SITE_VERIFICATION=abc123
