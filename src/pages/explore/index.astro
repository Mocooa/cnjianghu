---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/content/ArticleCard.astro';
import PillarGrid from '../../components/home/PillarGrid.astro';
import { getCollection } from 'astro:content';
import { getRoadmapStats } from '../../data/roadmap';

const allArticles = await getCollection('deep-dives', ({ data }) => !data.draft);
const sorted = allArticles.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const roadmapStats = getRoadmapStats();
---

<BaseLayout title="Explore" description="Browse all articles about Chinese culture">
  <div class="container-wide py-12">
    <h1 class="text-3xl md:text-4xl font-heading font-bold text-ink-900 dark:text-ink-50 mb-2">
      Explore
    </h1>
    <p class="text-ink-500 dark:text-ink-400 mb-10 max-w-2xl">
      Deep dives into Chinese culture — from internet memes to ancient philosophy, street food to space tech.
    </p>

    <div class="mb-8 flex flex-wrap gap-3 font-ui text-sm">
      <a
        href="/search"
        class="inline-flex items-center gap-2 rounded-full border border-ink-200 dark:border-ink-800 px-4 py-2 text-ink-600 dark:text-ink-300 hover:border-vermilion hover:text-vermilion transition-colors"
      >
        Search archive
      </a>
      <a
        href="/glossary"
        class="inline-flex items-center gap-2 rounded-full border border-ink-200 dark:border-ink-800 px-4 py-2 text-ink-600 dark:text-ink-300 hover:border-vermilion hover:text-vermilion transition-colors"
      >
        Browse glossary
      </a>
      <a
        href="/today"
        class="inline-flex items-center gap-2 rounded-full border border-ink-200 dark:border-ink-800 px-4 py-2 text-ink-600 dark:text-ink-300 hover:border-vermilion hover:text-vermilion transition-colors"
      >
        See today
      </a>
      <a
        href="/archive-map"
        class="inline-flex items-center gap-2 rounded-full border border-ink-200 dark:border-ink-800 px-4 py-2 text-ink-600 dark:text-ink-300 hover:border-vermilion hover:text-vermilion transition-colors"
      >
        Open archive map
      </a>
    </div>

    <div class="mb-10 rounded-3xl border border-ink-200 bg-white p-6 shadow-sm dark:border-ink-800 dark:bg-ink-900/70">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="text-xs font-ui font-semibold uppercase tracking-[0.18em] text-vermilion">
            Planning Surface
          </p>
          <h2 class="mt-2 text-2xl font-heading font-semibold text-ink-900 dark:text-ink-50">
            Review the full planned archive without mixing it into published content
          </h2>
          <p class="mt-3 max-w-2xl text-sm md:text-base text-ink-600 dark:text-ink-300">
            The roadmap layer currently exposes
            {' '}
            {roadmapStats.titleCount}
            {' '}
            planned titles across
            {' '}
            {roadmapStats.pillarCount}
            {' '}
            pillars,
            {' '}
            {roadmapStats.dossierCount}
            {' '}
            dossiers,
            and
            {' '}
            {roadmapStats.launchSlateCount}
            {' '}
            launch-slate priorities across
            {' '}
            {roadmapStats.waveCount}
            {' '}
            launch waves.
          </p>
        </div>

        <a
          href="/archive-map"
          class="inline-flex items-center justify-center rounded-full bg-vermilion px-5 py-3 text-sm font-ui font-medium text-white transition-colors hover:bg-vermilion-dark"
        >
          Open Archive Map
        </a>
      </div>
    </div>

    {sorted.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sorted.map((article, i) => (
          <ArticleCard
            title={article.data.title}
            summary={article.data.summary}
            slug={article.id}
            pillar={article.data.pillar}
            date={article.data.date}
            readingTime={article.data.reading_time}
            coverImage={article.data.cover_image}
            featured={i === 0}
          />
        ))}
      </div>
    ) : (
      <div class="text-center py-16">
        <p class="text-ink-400 dark:text-ink-500">Articles coming soon. Explore by pillar below.</p>
      </div>
    )}
  </div>

  <div class="border-t border-ink-200 dark:border-ink-800">
    <PillarGrid />
  </div>
</BaseLayout>
