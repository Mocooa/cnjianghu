---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search" description="Search cnjianghu for articles, glossary terms, and more.">
  <div class="container-article py-16 text-center">
    <h1 class="text-3xl font-heading font-bold text-ink-900 dark:text-ink-50 mb-4">
      Search
    </h1>
    <p class="text-ink-500 dark:text-ink-400 mb-8">
      Full-text search coming soon with Pagefind integration.
    </p>
    <div class="max-w-md mx-auto">
      <input
        type="search"
        placeholder="Search articles, glossary, topics..."
        class="w-full px-4 py-3 rounded-lg border border-ink-300 dark:border-ink-700 bg-white dark:bg-ink-900 text-ink-900 dark:text-ink-100 font-ui placeholder:text-ink-400 focus:outline-none focus:border-vermilion"
        disabled
      />
    </div>
  </div>
</BaseLayout>
