---
import BaseLayout from '../layouts/BaseLayout.astro';
import SearchWidget from '../components/search/SearchWidget';
---

<BaseLayout title="Search" description="Search cnjianghu for articles, glossary terms, and more.">
  <div class="container-wide py-16 md:py-20">
    <div class="max-w-3xl">
      <p class="text-sm font-ui font-semibold uppercase tracking-[0.18em] text-vermilion">
        Content Discovery
      </p>
      <h1 class="mt-3 text-4xl md:text-5xl font-heading font-bold text-ink-900 dark:text-ink-50">
        Search the jianghu
      </h1>
      <p class="mt-4 text-lg text-ink-500 dark:text-ink-400 leading-relaxed">
        Find deep dives, glossary terms, and daily quick bites across the entire archive.
      </p>
    </div>

    <div class="mt-10">
      <SearchWidget client:load />
    </div>
  </div>
</BaseLayout>
