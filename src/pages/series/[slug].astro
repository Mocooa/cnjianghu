---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSeriesArticles, getDeepDiveUrl } from '../../utils/content';
import { getPillar } from '../../utils/pillars';
import { seriesList, type SeriesInfo } from '../../data/series';

export function getStaticPaths() {
  return seriesList.map((s) => ({
    params: { slug: s.slug },
    props: { series: s },
  }));
}

const { series } = Astro.props as { series: SeriesInfo };
const articles = await getSeriesArticles(series.slug);
const pillarData = getPillar(series.pillar);
---

<BaseLayout title={`${series.name} — Series`} description={series.description}>
  <div class="container-article py-12">
    <nav class="flex items-center gap-2 text-sm font-ui text-ink-400 dark:text-ink-500 mb-6">
      <a href="/" class="hover:text-vermilion transition-colors">Home</a>
      <span>/</span>
      <a href="/series" class="hover:text-vermilion transition-colors">Series</a>
    </nav>

    {pillarData && (
      <span
        class="inline-block text-xs font-ui font-semibold uppercase tracking-wider mb-3"
        style={`color: var(--color-${pillarData.color})`}
      >
        {pillarData.icon} {pillarData.name}
      </span>
    )}

    <h1 class="text-3xl md:text-4xl font-heading font-bold text-ink-900 dark:text-ink-50 mb-3">
      {series.name}
    </h1>
    <p class="text-lg text-ink-600 dark:text-ink-400 max-w-2xl mb-10">
      {series.description}
    </p>

    <ol class="space-y-6">
      {articles.map((article, i) => {
        const part = article.data.series?.part ?? i + 1;
        return (
          <li>
            <a
              href={getDeepDiveUrl(article.id)}
              class="group block p-6 rounded-xl border border-ink-200 dark:border-ink-800 hover:border-vermilion dark:hover:border-vermilion transition-colors"
            >
              <div class="flex items-start gap-4">
                <span class="shrink-0 w-8 h-8 rounded-full bg-ink-100 dark:bg-ink-800 flex items-center justify-center text-sm font-ui font-bold text-ink-500 dark:text-ink-400 group-hover:bg-vermilion group-hover:text-white transition-colors">
                  {part}
                </span>
                <div class="min-w-0">
                  <h2 class="text-lg font-heading font-semibold text-ink-900 dark:text-ink-50 group-hover:text-vermilion transition-colors">
                    {article.data.title}
                  </h2>
                  {article.data.subtitle && (
                    <p class="mt-1 text-sm text-ink-500 dark:text-ink-400 line-clamp-2">
                      {article.data.subtitle}
                    </p>
                  )}
                  <div class="mt-2 flex items-center gap-3 text-xs font-ui text-ink-400 dark:text-ink-500">
                    {article.data.reading_time && <span>{article.data.reading_time} min read</span>}
                  </div>
                </div>
              </div>
            </a>
          </li>
        );
      })}
    </ol>
  </div>
</BaseLayout>
