---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Series" description="Multi-part deep dives into Chinese culture topics.">
  <div class="container-wide py-12">
    <h1 class="text-3xl md:text-4xl font-heading font-bold text-ink-900 dark:text-ink-50 mb-2">
      Series
    </h1>
    <p class="text-ink-500 dark:text-ink-400 mb-10 max-w-2xl">
      Multi-part journeys into the deep end of Chinese culture. Each series takes you from curious to informed.
    </p>

    <div class="text-center py-16">
      <div class="text-5xl mb-4">📚</div>
      <p class="text-ink-400 dark:text-ink-500">
        Our first series is in the works. Stay tuned.
      </p>
    </div>
  </div>
</BaseLayout>
