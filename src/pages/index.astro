---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import PillarGrid from '../components/home/PillarGrid.astro';
import ArticleCard from '../components/content/ArticleCard.astro';
import TodayQuickBiteRotator from '../components/content/TodayQuickBiteRotator';
import { getCollection } from 'astro:content';
import { selectDailyQuickBites, serializeQuickBiteEntry } from '../data/quick-bite-rotation.mjs';

// Get latest articles
const allDeepDives = await getCollection('deep-dives', ({ data }) => !data.draft);
const latestArticles = allDeepDives
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const allQuickBites = await getCollection('quick-bites', ({ data }) => !data.draft);
const serializedQuickBites = allQuickBites.map(serializeQuickBiteEntry);
const initialTodayBites = selectDailyQuickBites(serializedQuickBites, {
  now: new Date(),
  timeZone: 'Asia/Shanghai',
  maxItems: 4,
});
---

<BaseLayout title="Home">
  <HeroSection />

  {/* Latest Quick Bites */}
  {serializedQuickBites.length > 0 && (
    <section class="py-12 border-t border-ink-200 dark:border-ink-800">
      <div class="container-wide">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-heading font-semibold text-ink-900 dark:text-ink-50">
            Today's Quick Bites
          </h2>
          <a href="/today" class="text-sm font-ui text-vermilion-dark dark:text-vermilion-light hover:text-vermilion hover:underline">
            View all →
          </a>
        </div>
        <p class="mb-4 text-sm font-ui text-ink-500 dark:text-ink-400">
          Rotates daily on Shanghai time. If a type is missing, the remaining slots fall back to the newest available bites.
        </p>
        <TodayQuickBiteRotator
          client:load
          items={serializedQuickBites}
          initialItems={initialTodayBites}
          variant="home"
        />
      </div>
    </section>
  )}

  {/* Latest Deep Dives */}
  {latestArticles.length > 0 && (
    <section class="py-12 border-t border-ink-200 dark:border-ink-800">
      <div class="container-wide">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-heading font-semibold text-ink-900 dark:text-ink-50">
            Latest Deep Dives
          </h2>
          <a href="/explore" class="text-sm font-ui text-vermilion-dark dark:text-vermilion-light hover:text-vermilion hover:underline">
            View all →
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {latestArticles.map((article, i) => (
            <ArticleCard
              title={article.data.title}
              summary={article.data.summary}
              slug={article.id}
              pillar={article.data.pillar}
              date={article.data.date}
              readingTime={article.data.reading_time}
              coverImage={article.data.cover_image}
              featured={i === 0}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Pillar Grid (always shown) */}
  <div class="border-t border-ink-200 dark:border-ink-800">
    <PillarGrid />
  </div>

  {/* Empty state for new site */}
  {latestArticles.length === 0 && serializedQuickBites.length === 0 && (
    <section class="py-16">
      <div class="container-article text-center">
        <div class="text-6xl mb-4">📝</div>
        <h2 class="text-xl font-heading font-semibold text-ink-900 dark:text-ink-50 mb-2">
          Content coming soon
        </h2>
        <p class="text-ink-500 dark:text-ink-400 max-w-md mx-auto">
          The jianghu is being built. Check back soon for deep dives into Chinese culture, daily quick bites, and more.
        </p>
      </div>
    </section>
  )}
</BaseLayout>
