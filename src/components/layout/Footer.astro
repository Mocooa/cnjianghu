---
const year = new Date().getFullYear();
---

<footer class="border-t border-ink-200 dark:border-ink-800 mt-20">
  <div class="container-wide py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Brand -->
      <div>
        <a href="/" class="text-xl font-bold font-heading text-ink-900 dark:text-ink-50">
          cn<span class="text-vermilion">jianghu</span>
        </a>
        <p class="mt-3 text-sm text-ink-500 dark:text-ink-400 max-w-xs leading-relaxed">
          Go deeper into Chinese culture. Curated stories, decoded internet culture, and insider perspectives.
        </p>
      </div>

      <!-- Navigation -->
      <div class="font-ui">
        <h4 class="text-sm font-semibold text-ink-700 dark:text-ink-300 uppercase tracking-wider mb-3">Explore</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/explore/digital-china" class="text-ink-500 hover:text-vermilion transition-colors">Digital China</a></li>
          <li><a href="/explore/taste-life" class="text-ink-500 hover:text-vermilion transition-colors">Taste & Life</a></li>
          <li><a href="/explore/aesthetic-china" class="text-ink-500 hover:text-vermilion transition-colors">Aesthetic China</a></li>
          <li><a href="/explore/mind-china" class="text-ink-500 hover:text-vermilion transition-colors">Mind China</a></li>
          <li><a href="/explore/living-china" class="text-ink-500 hover:text-vermilion transition-colors">Living China</a></li>
          <li><a href="/explore/future-china" class="text-ink-500 hover:text-vermilion transition-colors">Future China</a></li>
        </ul>
      </div>

      <!-- Links -->
      <div class="font-ui">
        <h4 class="text-sm font-semibold text-ink-700 dark:text-ink-300 uppercase tracking-wider mb-3">Connect</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/about" class="text-ink-500 hover:text-vermilion transition-colors">About</a></li>
          <li><a href="/rss.xml" class="text-ink-500 hover:text-vermilion transition-colors">RSS Feed</a></li>
          <li><a href="https://github.com/Mocooa/cnjianghu" target="_blank" rel="noopener" class="text-ink-500 hover:text-vermilion transition-colors">GitHub</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-ink-200 dark:border-ink-800 flex flex-col sm:flex-row justify-between items-center gap-2">
      <p class="text-xs text-ink-400 dark:text-ink-600">
        &copy; {year} cnjianghu. Open source cultural project.
      </p>
      <p class="text-xs text-ink-400 dark:text-ink-600">
        Made with curiosity about <span class="font-chinese">江湖</span>
      </p>
    </div>
  </div>
</footer>
