---
import { tokenizeGlossaryLinkedTitle } from '../../data/glossary-inline-links.mjs';

interface Props {
  title: string;
  glossaryDependencyLookup?: Map<string, {
    slug: string;
    title: string;
    chinese: string;
    kind: 'term' | 'concept-note';
  }>;
}

const {
  title,
  glossaryDependencyLookup = new Map(),
} = Astro.props;

const titleTokens = tokenizeGlossaryLinkedTitle(title, glossaryDependencyLookup);
---

<>
  {titleTokens.map((token) => (
    token.type === 'link' ? (
      <a
        href={token.href}
        class:list={[
          'rounded px-1 py-0.5 transition-colors',
          token.kind === 'concept-note'
            ? 'bg-vermilion/8 text-vermilion hover:bg-vermilion/12'
            : 'bg-ink-100 text-ink-800 hover:bg-vermilion/10 hover:text-vermilion dark:bg-ink-800 dark:text-ink-100',
        ]}
      >
        {token.value}
      </a>
    ) : token.type === 'code' ? (
      <code class="rounded bg-ink-100 px-1 py-0.5 font-ui text-[0.92em] text-ink-700 dark:bg-ink-800 dark:text-ink-200">
        {token.value}
      </code>
    ) : (
      token.value
    )
  ))}
</>
