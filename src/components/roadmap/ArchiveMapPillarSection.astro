---
import PlannedTitleList from './PlannedTitleList.astro';
import type { RoadmapDossierGroup } from '../../data/roadmap';
import type { Pillar } from '../../utils/pillars';
import type { PlannedPillarSummary } from '../../data/roadmap';

interface Props {
  pillar: Pillar;
  groups: RoadmapDossierGroup[];
  summary: PlannedPillarSummary;
  glossaryLookup?: Record<string, {
    publishedEntries: Array<{
      slug: string;
      title: string;
      chinese: string;
      pinyin: string;
      kind: 'term' | 'concept-note';
    }>;
    plannedConcepts: Array<{
      term: string;
      slug: string;
      launchFirst: boolean;
      evergreen: boolean;
      titleCount: number;
    }>;
  }>;
  glossaryDependencyLookup?: Map<string, {
    slug: string;
    title: string;
    chinese: string;
    kind: 'term' | 'concept-note';
  }>;
}

const {
  pillar,
  groups,
  summary,
  glossaryLookup = {},
  glossaryDependencyLookup = new Map(),
} = Astro.props;
---

<section
  id={pillar.slug}
  class="scroll-mt-24 rounded-3xl border border-ink-200 bg-white p-6 shadow-sm dark:border-ink-800 dark:bg-ink-900/60 md:p-8"
>
  <div class="mb-8 flex flex-col gap-5 border-b border-ink-100 pb-6 dark:border-ink-800 lg:flex-row lg:items-end lg:justify-between">
    <div class="flex items-start gap-4">
      <span class="text-4xl">{pillar.icon}</span>
      <div>
        <p class="text-xs font-ui font-semibold uppercase tracking-[0.18em] text-vermilion">
          Pillar Roadmap
        </p>
        <h2 class="mt-2 text-2xl md:text-3xl font-heading font-semibold text-ink-900 dark:text-ink-50">
          {pillar.name}
        </h2>
        <p class="text-sm font-chinese text-ink-500 dark:text-ink-400">{pillar.chinese}</p>
        <p class="mt-3 max-w-2xl text-sm md:text-base text-ink-600 dark:text-ink-300">
          {pillar.description}
        </p>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-3">
      <span class="rounded-full bg-ink-100 px-3 py-1.5 text-sm font-ui text-ink-600 dark:bg-ink-800 dark:text-ink-200">
        {summary.titleCount} planned title{summary.titleCount === 1 ? '' : 's'}
      </span>
      <span class="rounded-full bg-ink-100 px-3 py-1.5 text-sm font-ui text-ink-600 dark:bg-ink-800 dark:text-ink-200">
        {summary.dossierCount} dossier{summary.dossierCount === 1 ? '' : 's'}
      </span>
      <span class="rounded-full bg-ink-100 px-3 py-1.5 text-sm font-ui text-ink-600 dark:bg-ink-800 dark:text-ink-200">
        {summary.launchCount} launch-first
      </span>
      <span class="rounded-full bg-ink-100 px-3 py-1.5 text-sm font-ui text-ink-600 dark:bg-ink-800 dark:text-ink-200">
        {summary.glossaryCount} glossary-backed
      </span>
      <a
        href={`/explore/${pillar.slug}`}
        class="inline-flex items-center gap-2 rounded-full border border-ink-200 px-4 py-2 text-sm font-ui text-ink-700 transition-colors hover:border-vermilion hover:text-vermilion dark:border-ink-700 dark:text-ink-200"
      >
        Open pillar page
      </a>
    </div>
  </div>

  <PlannedTitleList
    groups={groups}
    columns={2}
    pillarSlug={pillar.slug}
    glossaryLookup={glossaryLookup}
    glossaryDependencyLookup={glossaryDependencyLookup}
  />
</section>
