---
import { pillars } from '../../utils/pillars';
---

<section class="py-16">
  <div class="container-wide">
    <h2 class="text-2xl md:text-3xl font-heading font-semibold text-ink-900 dark:text-ink-50 mb-2">
      Explore by Pillar
    </h2>
    <p class="text-ink-600 dark:text-ink-300 mb-8 font-ui">
      Six lenses into Chinese culture
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {pillars.map(pillar => (
        <a
          href={`/explore/${pillar.slug}`}
          class="group block p-6 rounded-xl border border-ink-200 dark:border-ink-800 bg-white dark:bg-ink-900 hover:shadow-lg hover:border-ink-300 dark:hover:border-ink-700 transition-all"
        >
          <div class="text-3xl mb-3">{pillar.icon}</div>
          <h3 class="text-lg font-heading font-semibold text-ink-900 dark:text-ink-50 group-hover:text-vermilion transition-colors">
            {pillar.name}
          </h3>
          <span class="text-sm font-chinese text-ink-500 dark:text-ink-400">
            {pillar.chinese}
          </span>
          <p class="mt-2 text-sm text-ink-600 dark:text-ink-300 leading-relaxed">
            {pillar.description}
          </p>
        </a>
      ))}
    </div>
  </div>
</section>
