---

---

<section class="relative overflow-hidden py-20 md:py-32">
  <!-- Background texture -->
  <div class="absolute inset-0 opacity-5 dark:opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, var(--color-ink-900) 1px, transparent 0); background-size: 32px 32px;"></div>

  <div class="container-wide relative">
    <div class="max-w-3xl">
      <p class="font-ui text-[0.72rem] font-semibold uppercase tracking-[0.24em] text-ink-500 dark:text-ink-400 mb-4">
        Culture from the inside
      </p>

      <!-- Chinese accent -->
      <div class="font-chinese text-4xl md:text-6xl text-ink-200 dark:text-ink-800 mb-4 select-none" aria-hidden="true">
        江湖
      </div>

      <h1 class="text-4xl md:text-6xl font-heading font-bold text-ink-900 dark:text-ink-50 leading-tight">
        Welcome to the
        <span class="text-vermilion">Jianghu</span>
      </h1>

      <p class="mt-6 text-lg md:text-xl text-ink-600 dark:text-ink-400 max-w-2xl leading-relaxed">
        Not the China you see on the news, but the one you <span class="font-ui font-semibold text-ink-800 dark:text-ink-200">feel</span> when you're in it.
        Curated stories, decoded internet culture, and insider perspectives — for the curious.
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/explore"
          class="inline-flex items-center gap-2 px-6 py-3 bg-vermilion text-white font-ui font-medium rounded-lg hover:bg-vermilion-dark transition-colors"
        >
          Start Exploring
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
          </svg>
        </a>
        <a
          href="/search"
          class="inline-flex items-center gap-2 px-6 py-3 border border-ink-300 dark:border-ink-700 text-ink-700 dark:text-ink-300 font-ui font-medium rounded-lg hover:border-vermilion hover:text-vermilion transition-colors"
        >
          Search the Archive
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8" />
            <path d="m21 21-4.3-4.3" />
          </svg>
        </a>
      </div>

      <nav class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-3 font-ui text-sm text-ink-600 dark:text-ink-300" aria-label="Quick entry points">
        <span class="text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">
          Start with
        </span>
        <a href="/today" class="py-1 hover:text-vermilion transition-colors">Today</a>
        <a href="/glossary" class="py-1 hover:text-vermilion transition-colors">Glossary</a>
        <a href="/about" class="py-1 hover:text-vermilion transition-colors">About</a>
      </nav>
    </div>
  </div>
</section>
