---
import BaseLayout from './BaseLayout.astro';
import { getPillar } from '../utils/pillars';

interface Props {
  title: string;
  subtitle?: string;
  summary: string;
  pillar: string;
  date: Date;
  readingTime?: number;
  coverImage?: string;
  tags?: string[];
  sources?: Array<{ title: string; url: string; platform?: string }>;
  series?: {
    name: string;
    slug: string;
    part: number;
    total: number;
  };
}

const {
  title,
  subtitle,
  summary,
  pillar,
  date,
  readingTime,
  coverImage,
  tags = [],
  sources = [],
  series,
} = Astro.props;

const pillarData = getPillar(pillar);
const formattedDate = new Intl.DateTimeFormat('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}).format(date);
---

<BaseLayout title={title} description={summary} ogType="article">
  <article class="animate-fade-in">
    {/* Cover image */}
    {coverImage && (
      <div class="w-full h-64 md:h-96 overflow-hidden">
        <img
          src={coverImage}
          alt={title}
          class="w-full h-full object-cover"
        />
      </div>
    )}

    {/* Article header */}
    <header class="container-article pt-10 pb-8">
      {/* Breadcrumb */}
      <nav class="flex items-center gap-2 text-sm font-ui text-ink-400 dark:text-ink-500 mb-6">
        <a href="/" class="hover:text-vermilion transition-colors">Home</a>
        <span>/</span>
        <a href="/explore" class="hover:text-vermilion transition-colors">Explore</a>
        {pillarData && (
          <>
            <span>/</span>
            <a
              href={`/explore/${pillar}`}
              class="hover:text-vermilion transition-colors"
              style={`color: var(--color-${pillarData.color})`}
            >
              {pillarData.name}
            </a>
          </>
        )}
      </nav>

      {/* Series banner */}
      {series && (
        <div class="mb-6 p-3 rounded-lg bg-ink-100 dark:bg-ink-800 font-ui text-sm">
          <span class="text-ink-500 dark:text-ink-400">Part {series.part} of {series.total} in</span>
          <a href={`/series/${series.slug}`} class="ml-1 font-medium text-vermilion hover:underline">
            {series.name}
          </a>
        </div>
      )}

      {/* Pillar badge */}
      {pillarData && (
        <span
          class="inline-block text-xs font-ui font-semibold uppercase tracking-wider mb-3"
          style={`color: var(--color-${pillarData.color})`}
        >
          {pillarData.icon} {pillarData.name}
        </span>
      )}

      <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-ink-900 dark:text-ink-50 leading-tight">
        {title}
      </h1>

      {subtitle && (
        <p class="mt-3 text-xl text-ink-600 dark:text-ink-400 leading-relaxed">
          {subtitle}
        </p>
      )}

      <div class="mt-6 flex flex-wrap items-center gap-4 text-sm font-ui text-ink-500 dark:text-ink-400">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {readingTime && (
          <>
            <span class="text-ink-300 dark:text-ink-700">·</span>
            <span>{readingTime} min read</span>
          </>
        )}
      </div>

      {/* Tags */}
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="px-2.5 py-0.5 text-xs font-ui font-medium rounded-full bg-ink-100 dark:bg-ink-800 text-ink-600 dark:text-ink-400">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {/* Article body */}
    <div class="container-article prose dark:prose-invert">
      <slot />
    </div>

    {/* Sources */}
    {sources.length > 0 && (
      <footer class="container-article mt-12 pt-8 border-t border-ink-200 dark:border-ink-800">
        <h3 class="text-sm font-ui font-semibold uppercase tracking-wider text-ink-500 dark:text-ink-400 mb-3">
          Sources & Further Reading
        </h3>
        <ul class="space-y-2">
          {sources.map(source => (
            <li class="text-sm font-ui">
              <a
                href={source.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-vermilion hover:underline"
              >
                {source.title}
              </a>
              {source.platform && (
                <span class="ml-1 text-ink-400 dark:text-ink-500">
                  — {source.platform}
                </span>
              )}
            </li>
          ))}
        </ul>
      </footer>
    )}

    {/* Series navigation */}
    {series && (
      <nav class="container-article mt-8 py-6 border-t border-ink-200 dark:border-ink-800 flex justify-between font-ui text-sm">
        {series.part > 1 ? (
          <a href="#" class="text-vermilion hover:underline">← Previous</a>
        ) : <span />}
        <a href={`/series/${series.slug}`} class="text-ink-500 hover:text-vermilion">
          Series Overview ({series.part}/{series.total})
        </a>
        {series.part < series.total ? (
          <a href="#" class="text-vermilion hover:underline">Next →</a>
        ) : <span />}
      </nav>
    )}
  </article>
</BaseLayout>
