---
import BaseLayout from './BaseLayout.astro';
import { getPillar } from '../utils/pillars';
import ShareActions from '../components/content/ShareActions.astro';
import { getSeriesArticles, getDeepDiveUrl, getPublishedDeepDives } from '../utils/content';

interface Props {
  title: string;
  subtitle?: string;
  summary: string;
  pillar: string;
  date: Date;
  author?: string;
  readingTime?: number;
  coverImage?: string;
  ogImage?: string;
  tags?: string[];
  sources?: Array<{ title: string; url: string; platform?: string }>;
  series?: {
    name: string;
    slug: string;
    part: number;
    total: number;
  };
  related?: string[];
}

const {
  title,
  subtitle,
  summary,
  pillar,
  date,
  author = 'cnjianghu',
  readingTime,
  coverImage,
  ogImage,
  tags = [],
  sources = [],
  series,
  related = [],
} = Astro.props;

const pillarData = getPillar(pillar);

// Resolve series prev/next URLs
let seriesPrev: { url: string; title: string } | null = null;
let seriesNext: { url: string; title: string } | null = null;
if (series) {
  const seriesArticles = await getSeriesArticles(series.slug);
  const prevArticle = seriesArticles.find((a) => a.data.series?.part === series.part - 1);
  const nextArticle = seriesArticles.find((a) => a.data.series?.part === series.part + 1);
  if (prevArticle) seriesPrev = { url: getDeepDiveUrl(prevArticle.id), title: prevArticle.data.title };
  if (nextArticle) seriesNext = { url: getDeepDiveUrl(nextArticle.id), title: nextArticle.data.title };
}
// Resolve related article slugs to entries
const relatedArticles: Array<{ url: string; title: string; subtitle?: string; pillar: string }> = [];
if (related.length > 0) {
  const allArticles = await getPublishedDeepDives();
  for (const slug of related) {
    const match = allArticles.find((a) => a.id === slug);
    if (match) {
      relatedArticles.push({
        url: getDeepDiveUrl(match.id),
        title: match.data.title,
        subtitle: match.data.subtitle,
        pillar: match.data.pillar,
      });
    }
  }
}

const formattedDate = new Intl.DateTimeFormat('en-US', {
  weekday: 'long',
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}).format(date);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: summary,
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  mainEntityOfPage: canonicalUrl.toString(),
  articleSection: pillarData?.name ?? pillar,
  inLanguage: 'en',
  author: {
    '@type': 'Person',
    name: author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'cnjianghu',
    url: Astro.site?.toString() ?? canonicalUrl.origin,
  },
  ...(tags.length > 0 ? { keywords: tags.join(', ') } : {}),
  ...((ogImage ?? coverImage) ? { image: new URL(ogImage ?? coverImage!, Astro.site ?? Astro.url).toString() } : {}),
};
---

<BaseLayout title={title} description={summary} ogType="article" ogImage={ogImage} searchIndex={true}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <article class="animate-fade-in">
    {/* Cover image */}
    {coverImage && (
      <div class="w-full h-64 md:h-96 overflow-hidden">
        <img
          src={coverImage}
          alt={title}
          class="w-full h-full object-cover"
        />
      </div>
    )}

    {/* Article header */}
    <header class="container-article pt-10 pb-8">
      {/* Breadcrumb */}
      <nav class="flex items-center gap-2 text-sm font-ui text-ink-400 dark:text-ink-500 mb-6" data-pagefind-ignore>
        <a href="/" class="hover:text-vermilion transition-colors">Home</a>
        <span>/</span>
        <a href="/explore" class="hover:text-vermilion transition-colors">Explore</a>
        {pillarData && (
          <>
            <span>/</span>
            <a
              href={`/explore/${pillar}`}
              class="hover:text-vermilion transition-colors"
              style={`color: var(--color-${pillarData.color})`}
            >
              {pillarData.name}
            </a>
          </>
        )}
      </nav>

      {/* Series banner */}
      {series && (
        <div class="mb-6 p-3 rounded-lg bg-ink-100 dark:bg-ink-800 font-ui text-sm">
          <span class="text-ink-500 dark:text-ink-400">Part {series.part} of {series.total} in</span>
          <a href={`/series/${series.slug}`} class="ml-1 font-medium text-vermilion hover:underline">
            {series.name}
          </a>
        </div>
      )}

      {/* Pillar badge */}
      {pillarData && (
        <span
          class="inline-block text-xs font-ui font-semibold uppercase tracking-wider mb-3"
          style={`color: var(--color-${pillarData.color})`}
        >
          {pillarData.icon} {pillarData.name}
        </span>
      )}

      <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-ink-900 dark:text-ink-50 leading-tight">
        {title}
      </h1>

      {subtitle && (
        <p class="mt-3 text-xl text-ink-600 dark:text-ink-400 leading-relaxed">
          {subtitle}
        </p>
      )}

      <div class="mt-6 flex flex-wrap items-center gap-4 text-sm font-ui text-ink-500 dark:text-ink-400">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {readingTime && (
          <>
            <span class="text-ink-300 dark:text-ink-700">·</span>
            <span>{readingTime} min read</span>
          </>
        )}
      </div>

      {/* Tags */}
      {tags.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="px-2.5 py-0.5 text-xs font-ui font-medium rounded-full bg-ink-100 dark:bg-ink-800 text-ink-600 dark:text-ink-400">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {/* Article body */}
    <div class="container-article prose dark:prose-invert">
      <slot />
    </div>

    <ShareActions
      title={title}
      url={canonicalUrl.toString()}
      slug={Astro.url.pathname.split('/').filter(Boolean).at(-1) ?? 'article'}
    />

    {/* Sources */}
    {sources.length > 0 && (
      <footer class="container-article mt-12 pt-8 border-t border-ink-200 dark:border-ink-800" data-pagefind-ignore>
        <h3 class="text-sm font-ui font-semibold uppercase tracking-wider text-ink-500 dark:text-ink-400 mb-3">
          Sources & Further Reading
        </h3>
        <ul class="space-y-2">
          {sources.map(source => (
            <li class="text-sm font-ui">
              <a
                href={source.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-vermilion hover:underline"
              >
                {source.title}
              </a>
              {source.platform && (
                <span class="ml-1 text-ink-400 dark:text-ink-500">
                  — {source.platform}
                </span>
              )}
            </li>
          ))}
        </ul>
      </footer>
    )}

    {/* Related articles */}
    {relatedArticles.length > 0 && (
      <section class="container-article mt-10 pt-8 border-t border-ink-200 dark:border-ink-800" data-pagefind-ignore>
        <h3 class="text-sm font-ui font-semibold uppercase tracking-wider text-ink-500 dark:text-ink-400 mb-4">
          Keep Reading
        </h3>
        <div class="grid gap-4 sm:grid-cols-2">
          {relatedArticles.map(ra => {
            const raPillar = getPillar(ra.pillar);
            return (
              <a
                href={ra.url}
                class="group block p-4 rounded-lg border border-ink-200 dark:border-ink-800 hover:border-vermilion dark:hover:border-vermilion transition-colors"
              >
                {raPillar && (
                  <span
                    class="text-xs font-ui font-semibold uppercase tracking-wider"
                    style={`color: var(--color-${raPillar.color})`}
                  >
                    {raPillar.icon} {raPillar.name}
                  </span>
                )}
                <p class="mt-1 font-heading font-semibold text-ink-900 dark:text-ink-100 group-hover:text-vermilion transition-colors leading-snug">
                  {ra.title}
                </p>
                {ra.subtitle && (
                  <p class="mt-1 text-sm text-ink-500 dark:text-ink-400 line-clamp-2">
                    {ra.subtitle}
                  </p>
                )}
              </a>
            );
          })}
        </div>
      </section>
    )}

    {/* Series navigation */}
    {series && (
      <nav class="container-article mt-8 py-6 border-t border-ink-200 dark:border-ink-800 flex justify-between items-start font-ui text-sm" data-pagefind-ignore>
        {seriesPrev ? (
          <a href={seriesPrev.url} class="text-vermilion hover:underline max-w-[35%]">
            ← {seriesPrev.title}
          </a>
        ) : <span />}
        <a href={`/series/${series.slug}`} class="text-ink-500 hover:text-vermilion shrink-0">
          {series.part}/{series.total}
        </a>
        {seriesNext ? (
          <a href={seriesNext.url} class="text-vermilion hover:underline text-right max-w-[35%]">
            {seriesNext.title} →
          </a>
        ) : <span />}
      </nav>
    )}
  </article>
</BaseLayout>
